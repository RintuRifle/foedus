
# Foedus — Environment Variables
# Copy to .env and fill in your values

DATABASE_URL=postgresql+asyncpg://foedus:foedus_dev_2024@localhost:5432/foedus_db
DATABASE_URL_SYNC=postgresql://foedus:foedus_dev_2024@localhost:5432/foedus_db

REDIS_URL=redis://localhost:6379/0

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=foedus_tenders

JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_STORAGE_BUCKET=foedus-docs

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

RESEND_API_KEY=

LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=foedus

SENTRY_DSN=

APP_ENV=development
APP_DEBUG=true
APP_NAME=Foedus
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

SCRAPER_CRON_HOUR=6
SCRAPER_CRON_MINUTE=0
SCRAPER_MAX_PAGES=5
SCRAPER_PDF_DIR=./data/pdfs

# ── Free-tier architecture switches ──────────────────────────
# inline = evaluations run as asyncio tasks in the API process (512MB safe)
# celery = separate worker process (local dev / paid tier)
TASK_RUNNER=inline
# gemini = embeddings via API (no torch/RAM) | local = BGE-M3 (needs ~1GB RAM)
EMBEDDING_PROVIDER=gemini
EMBEDDING_DIM=768
# Token for POST /api/v1/scraper/trigger (external cron auth)
SCRAPER_TRIGGER_TOKEN=generate-a-random-string-here
